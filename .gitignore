# EAPS — .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
venv/
env/
.venv/
.env.local

# Secrets
.env

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Models (large binary files — use Git LFS or store separately)
models/*.pkl

# Data files (large CSVs)
data/*.csv

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Streamlit cache
.streamlit/secrets.toml

# Results (regenerated by pipeline)
results/*.png
